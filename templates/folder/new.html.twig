{% extends 'base.html.twig' %}

{% block title %}Hello FolderController!{% endblock %}

{% block body %}
<section class="h-screen flex items-center justify-center bg-gray-100">
    <div class="w-full max-w-lg bg-white p-6 rounded-lg text-black flex flex-col gap-4">
        
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-lg font-bold">Créer un dossier</h1>
                <p class="text-gray-500 text-sm">Organisez vos tâches par projet</p>
            </div>
            <a href="{{ path('app_dashboard') }}" class="text-gray-400 hover:text-gray-600 text-xl">✕</a>
        </div>
        {{ form_start(form) }}
        <div class="flex flex-col gap-1">
            <label class="text-sm font-medium">Nom du dossier</label>
            {{ form_widget(form.name, { attr: {
                class: 'w-full bg-gray-100 px-4 py-3 rounded-lg',
                placeholder: 'Ex: Travail'
            }}) }}
        </div>
        <div class="flex flex-col gap-2">
            <label class="text-sm font-medium">Couleur</label>
            <div class="grid grid-cols-8 gap-2">
                {% set colors = ['#EF4444', '#F97316', '#F59E0B', '#EAB308', '#84CC16', '#22C55E', '#10B981', '#14B8A6', '#06B6D4', '#0EA5E9', '#3B82F6', '#6366F1', '#8B5CF6', '#A855F7', '#D946EF', '#EC4899'] %}                {% for color in colors %}
            <label class="cursor-pointer">
            <input type="radio" name="folder_color" value="{{ color }}" class="hidden peer">
            <span class="block w-8 h-8 rounded-full peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-gray-800"
            style="background-color: {{ color }}"></span>
            </label>
                {% endfor %}
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-2">
            <a href="{{ path('app_dashboard') }}" 
               class="px-6 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 font-semibold">
                Annuler
            </a>
            <button type="submit" 
                    class="px-6 py-2 bg-black text-white rounded-lg text-sm hover:bg-gray-800">
                    <a href="{{ path('app_dashboard') }}">
                Créer
            </button>
        </div>
        {{ form_widget(form.color, { attr: { class: 'hidden' } }) }}
        {{ form_end(form) }}
    </div>
{% endblock %}
