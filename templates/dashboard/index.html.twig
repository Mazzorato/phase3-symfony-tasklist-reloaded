{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<section class="h-screen flex">
    <nav class="navbar flex-15/100 bg-[#F9FAFB] border-b border-gray-500 flex flex-col p-4">
        <a href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-900 text-sm mb-6 text-white">Toutes les Tâches</a>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Dossiers</p>
        <ul class="space-y-1">
            {% for folder in folders %}
                <li>
                    <a href="{{ path('app_dashboard_folder', {id: folder.id}) }}" class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-gray-100 text-sm text-gray-700">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 rounded-full" style="background-color: {{ folder.color }}"></div>
                            <p>{{ folder.name }}</p>
                        </div>
                        <p class="text-sm text-gray-400">{{ folder.tasks|length }}</p>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </nav>

    <div class="content flex flex-col flex-75/100">
        <header class="flex items-center justify-between px-8 py-4 bg-white border-b border-gray-200">
            <div>
                <h1 class="text-2xl text-black">Gestion de Tâches</h1>
                <p class="text-sm text-gray-500">Organisez votre journée efficacement</p>
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('app_priority') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-black rounded-lg hover:bg-gray-100">
                    Gérer les priorités
                </a>
                <a href="{{ path('app_folder_new') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-black border border-gray-300 rounded-lg hover:bg-gray-100">
                    Nouveau dossier
                </a>
                <a href="{{ path('app_task_new') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-white bg-gray-900 border border-gray-300 rounded-lg hover:bg-gray-700">
                    Nouvelle Tâche
                </a>
                <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-4 py-2 text-sm text-black border border-gray-300 rounded-lg hover:bg-gray-100">
                    Déconnexion
                </a>
            </div>
        </header>

        <main class="flex items-center gap-4 mb-6 px-8 py-4 bg-gray-100 border border-gray-200">
            <div class="flex items-center text-sm text-black gap-1">Filtres :</div>
            <div class="flex items-center gap-2">
                <label class="text-sm text-gray-900">Statut</label>
                <select class="text-sm border border-gray-300 rounded-lg px-3 py-2 bg-white">
                    <option>Tous</option>
                    <option>En cours</option>
                    <option>Terminé</option>
                    <option>Archivée</option>
                </select>
                <label class="text-sm text-gray-900">Priorité</label>
                <select class="text-sm border border-gray-300 rounded-lg px-3 py-2 bg-white">
                    <option>Toutes</option>
                    <option>Urgent</option>
                    <option>Important</option>
                    <option>Normal</option>
                </select>
            </div>
        </main>

        <div class="flex flex-col gap-3 px-8 py-4">
            {% for task in tasks %}
                {% set priorityColors = {
                    'urgent': 'bg-red-100 text-red-500',
                    'important': 'bg-orange-100 text-orange-500',
                    'normal': 'bg-blue-100 text-blue-600'
                } %}

                <div class="relative overflow-hidden flex items-center justify-between bg-white border border-gray-200 rounded-xl px-5 py-4 {{ task.status.value == 'archived' ? 'opacity-50' : '' }}">

                    {% if task.status.value == 'archived' %}
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <span class="text-2xl font-black tracking-widest text-green-600 bg-green-300 px-6 py-2 border border-green-300 rounded-lg rotate-[-15deg]">
                                ARCHIVÉE
                            </span>
                        </div>
                    {% endif %}

                    <div class="flex items-center gap-4">
                        <div class="flex flex-col items-center gap-1">
                            <form action="{{ path('app_task_status', {id: task.id}) }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('task_status' ~ task.id) }}">
                                <input type="hidden" name="status" value="{{ task.status.value == 'completed' ? 'pending' : 'completed' }}">
                                <input type="checkbox" onclick="this.form.submit()"
                                       {% if task.status.value == 'completed' %}checked{% endif %}>
                            </form>
                            <p class="text-xs text-gray-400">
                                {% if task.status.value == 'pending' %}En cours
                                {% elseif task.status.value == 'completed' %}Terminée
                                {% elseif task.status.value == 'archived' %}Archivée
                                {% endif %}
                            </p>
                        </div>

                        <div>
                            <a href="{{ path('app_task_edit', {id: task.id}) }}">
                                <p class="text-sm font-medium text-gray-800 {{ task.status.value == 'completed' ? 'line-through' : '' }}">
                                    {{ task.title }}
                                    {% if task.priority %}
                                        <span class="ml-2 text-xs px-2 py-0.5 rounded-full {{ priorityColors[task.priority.name] ?? 'bg-gray-100 text-gray-500' }}">
                                            {{ task.priority.name }}
                                        </span>
                                    {% endif %}
                                </p>
                            </a>
                        </div>
                    </div>

                    <form action="{{ path('app_task_status', {id: task.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('task_status' ~ task.id) }}">
                        <input type="hidden" name="status" value="archived">
                        <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-green-100 text-green-800 border border-green-200 rounded-lg hover:bg-gray-100">
                            Archiver
                        </button>
                    </form>

                </div>
            {% else %}
                <div class="flex items-center justify-center py-10">
                    <p class="text-gray-500">Aucune tâche pour le moment. Créez votre première tâche !</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}