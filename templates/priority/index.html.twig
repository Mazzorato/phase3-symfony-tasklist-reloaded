{% extends 'base.html.twig' %}
{% block title %}Gérer les priorités{% endblock %}
{% block body %}
<section class="h-screen flex items-center justify-center bg-gray-100">
    <div class="w-full max-w-lg bg-white p-6 rounded-lg text-black flex flex-col gap-4">
        
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-lg font-bold">Gérer les priorités</h1>
                <p class="text-gray-500 text-sm">Ajoutez ou supprimez des niveaux de priorité personnalisés</p>
            </div>
            <a href="{{ path('app_dashboard') }}" class="text-gray-400 hover:text-gray-600 text-xl">✕</a>
        </div>

        {{ form_start(form) }}
        <div class="flex gap-2">
            {{ form_widget(form.name, { attr: {
                class: 'w-full bg-gray-100 px-4 py-3 rounded-lg',
                placeholder: 'Ex: Très urgent'
            }}) }}
            <button type="submit" class="px-4 py-2 bg-black text-white rounded-lg hover:bg-gray-800">+</button>
        </div>
        {{ form_end(form) }}

        <p class="text-sm font-medium">Priorités existantes</p>
        <ul class="flex flex-col gap-2">
            {% for priority in priorities %}
                <li class="flex items-center justify-between px-4 py-3 border border-gray-200 rounded-lg text-sm">
                    {{ priority.name }}
                </li>
            {% endfor %}
        </ul>

    </div>
</section>
{% endblock %}