{% extends 'base.html.twig' %}
{% block title %}Modifier la tâche{% endblock %}
{% block body %}
<section class="h-screen flex items-center justify-center bg-gray-100">
    <div class="w-full max-w-lg bg-white p-6 rounded-lg text-black flex flex-col gap-4">

        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-lg font-bold">Modifier la tâche</h1>
            </div>
            <a href="{{ path('app_dashboard') }}" class="text-gray-400 hover:text-gray-600 text-xl">✕</a>
        </div>

        {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="flex justify-between gap-3 mt-2">
            <form action="{{ path('app_task_status', {id: task.id}) }}" method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('task_status' ~ task.id) }}">
                <input type="hidden" name="status" value="archived">
                <button type="submit" class="px-6 py-2 bg-gray-500 text-white rounded-lg text-sm hover:bg-gray-700">
                    Archiver
                </button>
            </form>
            <div class="flex gap-3">
                <a href="{{ path('app_dashboard') }}" class="px-6 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-2 bg-black text-white rounded-lg text-sm hover:bg-gray-800">
                    Modifier
                </button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
</section>
{% endblock %}