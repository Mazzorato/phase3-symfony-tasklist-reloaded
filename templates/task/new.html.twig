{% extends 'base.html.twig' %}
{% block title %}Nouvelle tâche{% endblock %}
{% block body %}
<section class="h-screen flex items-center justify-center bg-gray-100">
    <div class="w-full max-w-lg bg-white p-6 rounded-lg text-black flex flex-col gap-4">
        
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-lg font-bold">Créer une tâche</h1>
                <p class="text-gray-500 text-sm">Ajoutez une nouvelle tâche à votre liste</p>
            </div>
            <a href="{{ path('app_dashboard') }}" class="text-gray-400 hover:text-gray-600 text-xl">✕</a>
        </div>

        {{ form_start(form) }}

        <div class="flex flex-col gap-1">
            <label class="text-sm font-medium">Titre de la tâche</label>
            {{ form_widget(form.title, { attr: {
                class: 'w-full bg-gray-100 px-4 py-3 rounded-lg',
                placeholder: 'Faire les courses'
            }}) }}
        </div>

        <div class="flex flex-col gap-1">
            <label class="text-sm font-medium">Priorité</label>
            {{ form_widget(form.priority, { attr: {
                class: 'w-full bg-gray-100 px-4 py-3 rounded-lg'
            }}) }}
        </div>

        <div class="flex flex-col gap-1">
            <label class="text-sm font-medium">Dossier (optionnel)</label>
            {{ form_widget(form.folder, { attr: {
                class: 'w-full bg-gray-100 px-4 py-3 rounded-lg'
            }}) }}
        </div>

        <div class="flex justify-end gap-3 mt-2">
            <a href="{{ path('app_dashboard') }}" 
               class="px-6 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 font-semibold">
                Annuler
            </a>
            <button type="submit" 
                    class="px-6 py-2 bg-black text-white rounded-lg text-sm hover:bg-gray-800">
                Créer
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</section>
{% endblock %}